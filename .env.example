# ════════════════════════════════
# 🤖 TELEGRAM BOT
# ════════════════════════════════
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=Customcall9_bot
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_SECRET=your_random_secret_here
ADMIN_IDS=6566849366,5980615858
FORCE_JOIN_CHANNEL=@shuvon1ss

# ════════════════════════════════
# 📞 CALL API (Single Endpoint)
# ════════════════════════════════
CALL_API_URL=https://callapi.example.com/v1/send
CALL_API_KEY=your_call_api_key_here

# ════════════════════════════════
# 🗄️ DATABASE
# ════════════════════════════════
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/callbot
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ════════════════════════════════
# ⚡ REDIS & CELERY
# ════════════════════════════════
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ════════════════════════════════
# 💳 PAYMENT GATEWAYS
# ════════════════════════════════
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
BKASH_MERCHANT_NUMBER=01XXXXXXXXX

NAGAD_MERCHANT_ID=your_nagad_merchant_id
NAGAD_MERCHANT_NUMBER=01XXXXXXXXX
NAGAD_PG_KEY=your_nagad_pg_key

ROCKET_MERCHANT_NUMBER=01XXXXXXXXX

# ════════════════════════════════
# ⚙️ APP SETTINGS
# ════════════════════════════════
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=your_super_secret_key_here
ENCRYPTION_KEY=your_32_byte_fernet_key_here

MAX_CONCURRENT_CALLS=20
MAX_CALLS_PER_USER_PER_DAY=100
SINGLE_CALL_CREDIT_COST=1
BULK_CALL_CREDIT_COST=1

MAX_AUDIO_SIZE_MB=10
MAX_AUDIO_DURATION_SECONDS=120

REFERRAL_REWARD_CREDITS=10

# ════════════════════════════════
# 🔔 SENTRY (optional)
# ════════════════════════════════
SENTRY_DSN=your_sentry_dsn_here
